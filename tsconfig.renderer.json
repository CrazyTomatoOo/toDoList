{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "composite": true,
    "noEmit": false
  },
  "include": ["src/renderer", "src/shared", "index.html"],
  "exclude": ["src/main", "src/__tests__"]
}
